# ─────────────────────────────────────────────────────────────────────────────
# cni-net-lab — Lab Secrets
# Copy to lab.secrets (already in .gitignore) and fill in real values.
# This file is loaded automatically by load_lab_env() alongside lab.env.
#
# Values here can contain special characters (tokens, passwords) safely —
# load_lab_env() parses without shell eval.
# ─────────────────────────────────────────────────────────────────────────────

# ── NGINX Plus (Module 2+) ────────────────────────────────────────────────────
# JWT from MyF5 portal — used to pull from private-registry.nginx.com
# NGINX_JWT=

# ── BIG-IP CIS (Module 3) ─────────────────────────────────────────────────────
# Credentials for the BIG-IP management API
# BIGIP_USER=admin
# BIGIP_PASS=
# BIGIP_MGMT_IP=

# ── DockerHub (optional) ──────────────────────────────────────────────────────
# Avoids anonymous pull rate limits when caching images
# DOCKERHUB_USER=
# DOCKERHUB_PASS=
