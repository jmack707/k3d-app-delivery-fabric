diff --git a/apps/crapi/chart/templates/mailhog/ingress.yaml b/apps/crapi/chart/templates/mailhog/ingress.yaml
index c51e41b..ff15e1b 100644
--- a/apps/crapi/chart/templates/mailhog/ingress.yaml
+++ b/apps/crapi/chart/templates/mailhog/ingress.yaml
@@ -12,9 +12,14 @@ spec:
   ports:
   - name: web
     port: {{ .Values.mailhog.webPort }}
-    nodePort: {{ .Values.mailhog.webService.nodePort }}
     protocol: TCP
+    {{- if ne (.Values.mailhog.webService.type | default "LoadBalancer") "ClusterIP" }}
+    nodePort: {{ .Values.mailhog.webService.nodePort }}
+    {{- end }}
   selector:
     {{- toYaml .Values.mailhog.serviceSelectorLabels | nindent 4 }}
   sessionAffinity: None
-  type: LoadBalancer
+  # Lab override (cni-net-lab): default LoadBalancer never gets an IP here
+  # (ServiceLB disabled), which leaves Argo CD stuck Progressing. MailHog is
+  # reached via 'task crapi:mail', so the lab sets this to ClusterIP.
+  type: {{ .Values.mailhog.webService.type | default "LoadBalancer" }}
diff --git a/apps/crapi/chart/templates/web/ingress.yaml b/apps/crapi/chart/templates/web/ingress.yaml
index 19e632d..6f71e64 100644
--- a/apps/crapi/chart/templates/web/ingress.yaml
+++ b/apps/crapi/chart/templates/web/ingress.yaml
@@ -9,12 +9,18 @@ spec:
   ports:
   - port: {{ .Values.web.port }}
     targetPort: 80
+    {{- if ne (.Values.web.service.type | default "LoadBalancer") "ClusterIP" }}
     nodePort: {{ .Values.web.service.nodePort }}
+    {{- end }}
     name: nginx
   - port: {{ .Values.web.sslPort }}
     targetPort: 443
+    {{- if ne (.Values.web.service.type | default "LoadBalancer") "ClusterIP" }}
     nodePort: {{ .Values.web.service.sslNodePort }}
+    {{- end }}
     name: nginx-ssl
-  type: LoadBalancer
+  # Lab override (cni-net-lab): web.service.type lets the lab switch crAPI
+  # between NodePort and ClusterIP. Upstream default stays LoadBalancer.
+  type: {{ .Values.web.service.type | default "LoadBalancer" }}
   selector:
     {{- toYaml .Values.web.serviceSelectorLabels | nindent 4 }}
