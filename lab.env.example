# ─────────────────────────────────────────────────────────────────────────────
# k3d-app-delivery-fabric — Lab Configuration
# Copy to lab.env and edit before running 'task up'
# Credentials go in lab.secrets (gitignored)
# ─────────────────────────────────────────────────────────────────────────────

# ── Network ───────────────────────────────────────────────────────────────────
# Host IP reachable by external clients.
# Run: ip route get 1.1.1.1 | grep -oP 'src \K[\d.]+'
LAB_HOST_IP=172.16.1.136

# Base domain for app hostnames (used only for /etc/hosts hints and TLS SANs)
LAB_DOMAIN=lab.local

# ── Cluster ───────────────────────────────────────────────────────────────────
CLUSTER_NAME=k3d-app-delivery-fabric

# CNI: calico | cilium
# Changing CNI requires 'task reset'
CNI=cilium

# Number of k3d agent nodes (server always = 1).
# Changing this requires 'task reset'.
LAB_AGENTS=2

# ── Apps ──────────────────────────────────────────────────────────────────────
# Which apps deploy and how each is exposed (NodePort/ClusterIP, HTTP/HTTPS) is
# defined entirely in Gitea — argocd/lab-apps/values.yaml (enabled per app) and
# the profile files. There is no app list here; 'task health'/'test' read the
# live cluster. The two knobs below just SELECT which committed config Argo uses.

# ── Exposure profile ──────────────────────────────────────────────────────────
# One switch for how ALL apps are exposed. Selects a committed scenario file
# (argocd/lab-apps/profiles/<profile>.yaml) that Argo CD layers over the base values.
#   mixed            — original per-app mix (juiceshop HTTPS, dvga/vampi ClusterIP)
#   nodeport-http    — all apps NodePort, HTTP only
#   nodeport-https   — all apps NodePort, HTTPS
#   clusterip-http   — all apps ClusterIP, HTTP   (ingress-prep, not on host)
#   clusterip-https  — all apps ClusterIP, HTTPS  (ingress-prep, not on host)
# Switch profiles: edit this, then 'task argocd:bootstrap && task argocd:wait'.
LAB_PROFILE=mixed

# ── Ingress / routing layer ────────────────────────────────────────────────────
# Optional north-south routing in front of the apps. Apps keep their own
# (NodePort) Services; this layer adds controller-specific resources pointing at
# them (argocd/exposure). Per-controller settings live in argocd/exposure/values.yaml.
#   none    — no routing layer (default)
#   nginx   — networking.k8s.io/v1 Ingress (needs an NGINX ingress controller)
#   cis     — F5 BIG-IP CIS VirtualServer (needs CIS CRDs + controller + BIG-IP)
#   gateway — Gateway API HTTPRoute (needs Gateway API CRDs, e.g. NGINX Gateway Fabric)
# Change it, then: task argocd:bootstrap && task argocd:wait
INGRESS_KIND=none

# ── NodePort ranges ────────────────────────────────────────────────────────────
# Bands of host NodePorts published at cluster creation (change requires
# 'task reset'). The cluster no longer needs per-app ports — any app NodePort
# that falls in these ranges is reachable on LAB_HOST_IP without a rebuild.
#
# The per-app port assignments now live in Gitea: argocd/lab-apps/values.yaml
# (httpNodePort / httpsNodePort). Keep those within the ranges below.
# Defaults cover app HTTP 30080-30083 + Argo CD 30090, and app HTTPS 30443-30446.
NODEPORT_RANGES="30080-30099 30440-30459"

# ── Argo CD (GitOps) ───────────────────────────────────────────────────────────
# Argo CD manages every app from this git repo. The UI/API server is exposed as
# a NodePort (no ingress in this lab); it must fall within NODEPORT_RANGES.
ARGOCD_HTTP_PORT=30090

# Where Argo CD pulls manifests from. Leave blank to auto-detect, in order:
#   1. a running self-hosted Gitea with the lab repo (task gitea:setup), else
#   2. the 'origin' git remote.
# Target revision blank = the currently checked-out branch.
# Set these explicitly to pin a specific repo/branch (an explicit value wins):
#   ARGOCD_REPO_URL=https://github.com/<you>/k3d-app-delivery-fabric.git
#   ARGOCD_TARGET_REVISION=main
# NOTE: if your repo is PRIVATE and you rely on origin, Argo needs a credential
# (ARGOCD_REPO_USERNAME/PASSWORD in lab.secrets); the Gitea path is public.
ARGOCD_REPO_URL=
ARGOCD_TARGET_REVISION=

# ── Registry ──────────────────────────────────────────────────────────────────
# Plain Docker registry v2, runs as a container on the host.
# Bound to both 127.0.0.1:REGISTRY_PORT and LAB_HOST_IP:REGISTRY_PORT.
REGISTRY_PORT=5000
REGISTRY_NAME=k3d-app-delivery-fabric-registry

# ── Self-hosted Git (Gitea, optional) ──────────────────────────────────────────
# Run Gitea as a host container (like the registry) to use as Argo CD's source
# of truth instead of GitHub — keeps the lab fully self-contained / air-gappable.
# Start with: task gitea:setup
GITEA_HTTP_PORT=3000
GITEA_NAME=k3d-app-delivery-fabric-gitea
GITEA_REPO=k3d-app-delivery-fabric
GITEA_ADMIN_USER=giteaadmin
# GITEA_IMAGE=gitea/gitea:1.22
#
# 'task gitea:setup' creates the repo (public) and WRITES ARGOCD_REPO_URL /
# ARGOCD_TARGET_REVISION above for you, then you run:
#   task argocd:bootstrap && task argocd:wait
# Even if those stay blank, the bootstrap auto-detects a running Gitea. No
# ARGOCD_REPO_PASSWORD is needed (the Gitea repo is public).

# ── Argo CD sync wait ──────────────────────────────────────────────────────────
# How long 'task up' (via task argocd:wait) blocks for all Applications to
# become Synced + Healthy before running the final health check. crAPI's full
# cold start (postgres + mongo + identity + community + workshop + web, with
# image pulls) can take several minutes on first run.
ARGOCD_WAIT_TIMEOUT=900
