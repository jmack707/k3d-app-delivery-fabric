# ─────────────────────────────────────────────────────────────────────────────
# cni-net-lab — Lab Configuration
# Copy to lab.env and edit before running 'task up'
# Credentials go in lab.secrets (gitignored)
# ─────────────────────────────────────────────────────────────────────────────

# ── Network ───────────────────────────────────────────────────────────────────
# Host IP reachable by external clients.
# Run: ip route get 1.1.1.1 | grep -oP 'src \K[\d.]+'
LAB_HOST_IP=172.16.1.136

# Base domain for app hostnames (used only for /etc/hosts hints and TLS SANs)
LAB_DOMAIN=lab.local

# ── Cluster ───────────────────────────────────────────────────────────────────
CLUSTER_NAME=cni-net-lab

# CNI: calico | cilium
# Changing CNI requires 'task reset'
CNI=cilium

# Number of k3d agent nodes (server always = 1).
# Changing this requires 'task reset'.
LAB_AGENTS=2

# ── Apps ──────────────────────────────────────────────────────────────────────
# Space-separated list of apps to deploy on 'task up'.
# Valid: crapi juiceshop dvga vampi
# Memory cost: crapi ~2GB, juiceshop ~300MB, dvga ~200MB, vampi ~100MB
LAB_APPS="crapi juiceshop dvga vampi"

# Apps that get HTTPS (cert-manager + local CA).
# Apps NOT in this list get plain HTTP only.
# Must be a subset of LAB_APPS.
HTTPS_APPS="crapi juiceshop"

# Apps exposed as ClusterIP instead of NodePort.
# - Apps NOT in this list default to NodePort (reachable on LAB_HOST_IP:port).
# - Apps in this list get ClusterIP — NOT reachable from the host; use
#   'kubectl port-forward' or an in-cluster ingress (BIG-IP/NGINX) to reach them.
# Useful when prepping an app to sit behind an ingress controller.
# Leave empty for all-NodePort (the default lab behavior).
CLUSTERIP_APPS="dvga vampi"

# ── NodePort assignments ───────────────────────────────────────────────────────
# Fixed ports bound at cluster creation. Change requires 'task reset'.
# HTTP ports
CRAPI_HTTP_PORT=30080
JUICESHOP_HTTP_PORT=30081
DVGA_HTTP_PORT=30082
VAMPI_HTTP_PORT=30083

# HTTPS ports (only used when app is in HTTPS_APPS)
CRAPI_HTTPS_PORT=30443
JUICESHOP_HTTPS_PORT=30444
DVGA_HTTPS_PORT=30445
VAMPI_HTTPS_PORT=30446

# ── Registry ──────────────────────────────────────────────────────────────────
# Plain Docker registry v2, runs as a container on the host.
# Bound to both 127.0.0.1:REGISTRY_PORT and LAB_HOST_IP:REGISTRY_PORT.
REGISTRY_PORT=5000
REGISTRY_NAME=cni-lab-registry

# ── Helm tuning (crAPI only) ──────────────────────────────────────────────────
# How long Helm waits for the chart to roll out before giving up.
# crAPI's full cold start (postgres + mongo + identity + community + workshop
# + web, with image pulls) can take 5-10 minutes on first run.
HELM_TIMEOUT=15m

# Whether 'helm install' blocks until every pod is Ready.
# - true (default): Helm returns only when pods are healthy
# - false: Helm returns immediately; app-up.sh's pod-readiness check handles
#   the wait instead. Useful if Helm's --wait is unreliable for your chart.
HELM_WAIT=true
